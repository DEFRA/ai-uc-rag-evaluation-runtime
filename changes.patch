diff --git a/scripts/check-unpinned-dependencies.sh b/scripts/check-unpinned-dependencies.sh
new file mode 100755
index 0000000..5a66a87
--- /dev/null
+++ b/scripts/check-unpinned-dependencies.sh
@@ -0,0 +1,24 @@
+#!/bin/bash
+
+# Check if pyproject.toml exists
+if [ ! -f "pyproject.toml" ]; then
+    echo "pyproject.toml not found!"
+    exit 1
+fi
+
+# Extract dependencies from pyproject.toml and check for unpinned versions
+unpinned_deps=$(grep -A 50 "^dependencies = \[" pyproject.toml | grep -E '^\s*"' | grep -v '==' | grep -v '>=' | grep -v '<=' | grep -v '~=' | grep -v '!=' | grep -v '>' | grep -v '<' | head -20)
+
+if [ -n "$unpinned_deps" ]; then
+    echo "⚠️  WARNING: Found potentially unpinned dependencies:"
+    echo "$unpinned_deps"
+    echo
+    echo "Consider pinning these dependencies to specific versions for better reproducibility."
+    echo "Example: 'package==1.2.3' instead of 'package'"
+    echo
+    echo "This is a warning only - the build will continue."
+else
+    echo "✅ All main dependencies appear to be pinned to specific versions."
+fi
+
+echo "✅ Dependency check completed."
